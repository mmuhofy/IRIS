Replace hardcoded com.termux references with $TERMUX_APP_PACKAGE in termux-tools.

This allows the package to be built for any Android package name (not just
com.termux). Scripts like termux-setup-package-manager reference the package
name internally for path resolution.

diff --git a/packages/termux-tools/build.sh b/packages/termux-tools/build.sh
index b833aa1c0..50a1c4cbc 100644
--- a/packages/termux-tools/build.sh
+++ b/packages/termux-tools/build.sh
@@ -19,5 +19,12 @@ TERMUX_PKG_DEPENDS="coreutils, curl, dash, diffutils, findutils, gawk, grep, les
 TERMUX_PKG_RECOMMENDS="ed, dos2unix, inetutils, net-tools, patch, unzip"
 
 termux_step_pre_configure() {
+	# Replace hardcoded com.termux references with custom package name.
+	# This is needed when building for a non-default TERMUX_APP_PACKAGE.
+	# The scripts installed by termux-tools reference the package name in
+	# paths like /data/data/com.termux/files/usr/...
+	find . -type f -print0 | xargs -0 sed -i \
+		"s/com\.termux/$TERMUX_APP_PACKAGE/g"
+
 	# Remove the placeholder "${TERMUX_PREFIX}/bin/termux-setup-package-manager"
 	# so that termux_step_massage() does not add it to the removal list.

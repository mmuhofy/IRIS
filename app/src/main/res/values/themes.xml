<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base theme: Theme.MaterialComponents.DayNight.NoActionBar
        - AppCompat-derived (required by ComponentActivity + SplashScreen API)
        - No action bar (Compose handles all UI)
        - All actual theming handled in Compose MaterialTheme
    -->
    <style name="Theme.IRIS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="Theme.IRIS.Translucent" parent="Theme.IRIS">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
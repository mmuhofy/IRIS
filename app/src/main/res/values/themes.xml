<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Base theme: Theme.MaterialComponents.DayNight.NoActionBar
        - AppCompat-derived (required by ComponentActivity + SplashScreen API)
        - No action bar (Compose handles all UI)
        - All actual theming handled in Compose MaterialTheme
    -->
    <style name="Theme.IRIS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <!-- Splash screen background color (shown before Compose loads) -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/splash_background</item>
    </style>

    <!--
        Post-splash theme — applied after splash finishes.
        Must not have a window background that conflicts with Compose.
    -->
    <style name="Theme.IRIS.NoSplash" parent="Theme.IRIS">
        <item name="android:windowSplashScreenAnimatedIcon" tools:ignore="NewApi">@mipmap/ic_launcher</item>
    </style>
</resources>